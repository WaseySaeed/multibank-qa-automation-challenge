{
  "name": "multibank-qa-automation-challenge",
  "version": "1.0.0",
  "description": "MultiBank QA Automation Coding Challenge - Playwright test suite for trade.mb.io",
  "scripts": {
    "test": "playwright test",
    "test:navigation": "playwright test tests/navigation.spec.ts",
    "test:content-links": "playwright test tests/contentLinks.spec.ts",
    "test:negative": "playwright test tests/negative.spec.ts",
    "test:trading": "playwright test tests/trading.spec.ts",
